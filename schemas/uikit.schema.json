{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "UIKit JSON Schema",
  "description": "Schema for recursica_ui-kit.json structure",
  "type": "object",
  "required": ["ui-kit"],

  "definitions": {
    "dtcgToken": {
      "type": "object",
      "required": ["$value"],
      "properties": {
        "$type": { "type": "string" },
        "$value": {},
        "$description": { "type": "string" },
        "$extensions": { "type": "object" },
        "$deprecated": {},
        "$extends": {}
      },
      "additionalProperties": false
    },

    "componentSlotExtension": {
      "description": "DTCG §6 $extensions payload for a component-slot group. Declares that this group in a component's properties binds to another component and pre-selects its variants.",
      "type": "object",
      "required": ["recursica.component-slot"],
      "properties": {
        "recursica.component-slot": {
          "type": "object",
          "required": ["component"],
          "properties": {
            "component": {
              "type": "string",
              "description": "The name of the component being slotted (e.g. \"button\"). Must match a key in ui-kit.components."
            },
            "selected-variants": {
              "type": "object",
              "description": "Pre-selected variant values keyed by variant dimension name (e.g. { \"style\": \"solid\", \"size\": \"small\" }). Values are plain variant names, not references.",
              "additionalProperties": { "type": "string" }
            },
            "selected-props": {
              "type": "object",
              "description": "Optional overrides for specific component property tokens within the slotted component.",
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": false
    },

    "componentSlotGroup": {
      "description": "A group node (no $value) that declares a component-slot via $extensions.",
      "type": "object",
      "required": ["$extensions"],
      "properties": {
        "$description": { "type": "string" },
        "$extensions": { "$ref": "#/definitions/componentSlotExtension" }
      },
      "additionalProperties": false
    }
  },

  "properties": {
    "ui-kit": {
      "type": "object",
      "required": ["globals"],
      "properties": {
        "globals": {
          "type": "object",
          "properties": {
            "icon": { "type": "object" },
            "form": { "type": "object" },
            "indicators": { "type": "object" },
            "field": { "type": "object" },
            "label": { "type": "object" },
            "assistive-elements": { "type": "object" }
          },
          "additionalProperties": true
        },
        "components": {
          "type": "object",
          "patternProperties": {
            "^[a-z0-9-]+$": {
              "type": "object",
              "properties": {
                "variants": {
                  "type": "object",
                  "additionalProperties": true
                },
                "properties": {
                  "type": "object",
                  "description": "Component-level property tokens and component-slot groups.",
                  "additionalProperties": true
                },
                "size": { "type": "object" }
              },
              "additionalProperties": true
            }
          },
          "additionalProperties": false
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
