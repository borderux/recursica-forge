{
  "ui-kit": {
    "globals": {
      "icon": {
        "style": {
          "$type": "string",
          "$value": "outline"
        }
      },
      "form": {
        "properties": {
          "label-field-gap-horizontal": {
            "$type": "dimension",
            "$value": "{brand.dimensions.gutters.horizontal}"
          },
          "label-field-gap-vertical": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "vertical-item-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          }
        },
        "field": {
          "colors": {
            "background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.tone}"
            },
            "background-read-only": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "border": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.default.color.tone}"
            },
            "border-focus": {
              "$type": "color",
              "$value": "{brand.palettes.palette-1.default.color.tone}"
            },
            "border-selected": {
              "$type": "color",
              "$value": "{brand.palettes.palette-1.default.color.tone}"
            },
            "border-error": {
              "$type": "color",
              "$value": "{brand.palettes.core-colors.alert.tone}"
            },
            "icon": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.on-tone}"
            },
            "text-valued": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.on-tone}"
            },
            "placeholder-text-opacity": {
              "$type": "number",
              "$value": "{brand.text-emphasis.low}"
            },
            "disabled-background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "disabled-text": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.400.color.tone}"
            }
          },
          "size": {
            "border-radius": {
              "$type": "dimension",
              "$value": "{brand.dimensions.border-radii.default}"
            },
            "border-size-default": {
              "$type": "dimension",
              "$value": {
                "value": 1,
                "unit": "px"
              }
            },
            "border-size-focus": {
              "$type": "dimension",
              "$value": {
                "value": 2,
                "unit": "px"
              }
            },
            "icon-text-gap": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            },
            "single-line-input-height": {
              "$type": "dimension",
              "$value": {
                "value": 48,
                "unit": "px"
              }
            },
            "horizontal-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.lg}"
            },
            "icon": {
              "$type": "dimension",
              "$value": "{brand.dimensions.icons.default}"
            },
            "max-width": {
              "$type": "dimension",
              "$value": {
                "value": 464,
                "unit": "px"
              }
            },
            "min-width": {
              "$type": "dimension",
              "$value": {
                "value": 140,
                "unit": "px"
              }
            },
            "vertical-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.md}"
            },
            "vertical-gutter": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            }
          }
        }
      }
    },
    "components": {
      "pagination": {
        "properties": {
          "colors": {
            "layer-0": {
              "dots-color": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.success.tone}"
              }
            },
            "layer-1": {
              "dots-color": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.600.color.tone}"
              }
            },
            "layer-2": {
              "dots-color": {
                "$type": "color",
                "$value": "{brand.palettes.palette-2.300.color.tone}"
              }
            },
            "layer-3": {
              "dots-color": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.100.color.tone}"
              }
            }
          },
          "item-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "active-pages": {
            "$value": "{ui-kit.components.button}",
            "$extensions": {
              "recursica.component": {
                "selected-variants": {
                  "style": "{ui-kit.components.button.variants.styles.solid}",
                  "size": "{ui-kit.components.button.variants.sizes.small}"
                }
              }
            }
          },
          "inactive-pages": {
            "$value": "{ui-kit.components.button}",
            "$extensions": {
              "recursica.component": {
                "selected-variants": {
                  "style": "{ui-kit.components.button.variants.styles.outline}",
                  "size": "{ui-kit.components.button.variants.sizes.small}"
                }
              }
            }
          },
          "navigation-controls": {
            "$value": "{ui-kit.components.button}",
            "$extensions": {
              "recursica.component": {
                "selected-variants": {
                  "style": "{ui-kit.components.button.variants.styles.text}",
                  "size": "{ui-kit.components.button.variants.sizes.small}",
                  "content": "{ui-kit.components.button.variants.content.icon-only}"
                }
              }
            }
          }
        }
      }
    }
  }
}
