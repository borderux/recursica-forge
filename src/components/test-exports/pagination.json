{
  "ui-kit": {
    "components": {
      "pagination": {
        "properties": {
          "colors": {
            "layer-0": {
              "dots-color": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.500.color.tone}"
              }
            },
            "layer-1": {
              "dots-color": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.500.color.tone}"
              }
            },
            "layer-2": {
              "dots-color": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.500.color.tone}"
              }
            },
            "layer-3": {
              "dots-color": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.500.color.tone}"
              }
            }
          },
          "item-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "active-pages": {
            "$value": "{brand.palettes.neutral.500.color.tone}",
            "$extensions": {
              "recursica.component": {
                "selected-variants": {
                  "style": "{ui-kit.components.button.variants.styles.solid}",
                  "size": "{ui-kit.components.button.variants.sizes.small}"
                }
              }
            }
          },
          "inactive-pages": {
            "$value": "{brand.palettes.neutral.500.color.tone}",
            "$extensions": {
              "recursica.component": {
                "selected-variants": {
                  "style": "{ui-kit.components.button.variants.styles.outline}",
                  "size": "{ui-kit.components.button.variants.sizes.small}"
                }
              }
            }
          },
          "navigation-controls": {
            "$value": "{brand.palettes.neutral.500.color.tone}",
            "$extensions": {
              "recursica.component": {
                "selected-variants": {
                  "style": "{ui-kit.components.button.variants.styles.text}",
                  "size": "{ui-kit.components.button.variants.sizes.small}",
                  "content": "{ui-kit.components.button.variants.content.icon-only}"
                }
              }
            }
          }
        }
      }
    }
  }
}