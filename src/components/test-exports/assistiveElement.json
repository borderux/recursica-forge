          },
          "icon-text-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.md}"
          },
          "top-margin": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "max-width": {
            "$type": "dimension",
            "$value": {
              "value": 502,
              "unit": "px"
            }
          }
        }
