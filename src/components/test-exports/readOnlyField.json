{
  "ui-kit": {
    "components": {
      "read-only-field": {
        "variants": {
          "layouts": {
            "stacked": {
              "properties": {
                "top-bottom-margin": {
                  "$type": "dimension",
                  "$value": "{brand.dimensions.general.2xl}"
                }
              }
            },
            "side-by-side": {
              "properties": {
                "top-bottom-margin": {
                  "$type": "dimension",
                  "$value": "{brand.dimensions.general.lg}"
                }
              }
            }
          }
        },
        "properties": {
          "colors": {
            "layer-0": {
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.500.color.tone}"
              }
            },
            "layer-1": {
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.500.color.tone}"
              }
            },
            "layer-2": {
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.500.color.tone}"
              }
            },
            "layer-3": {
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.500.color.tone}"
              }
            }
          },
          "text": {
            "font-family": {
              "$type": "string",
              "$value": "{brand.fonts.primary}"
            },
            "font-size": {
              "$type": "dimension",
              "$value": "{tokens.font.sizes.5xl}"
            },
            "font-weight": {
              "$type": "number",
              "$value": "{tokens.font.weights.bold}"
            },
            "letter-spacing": {
              "$type": "string",
              "$value": "{tokens.font.letter-spacings.tight}"
            },
            "line-height": {
              "$type": "number",
              "$value": "{tokens.font.line-heights.default}"
            },
            "text-decoration": {
              "$type": "string",
              "$value": "{tokens.font.decorations.line-through}"
            },
            "text-transform": {
              "$type": "string",
              "$value": "{tokens.font.cases.titlecase}"
            },
            "font-style": {
              "$type": "string",
              "$value": "{tokens.font.styles.normal}"
            }
          },
          "min-height": {
            "$type": "dimension",
            "$value": {
              "value": 408,
              "unit": "px"
            }
          }
        }
      }
    }
  }
}