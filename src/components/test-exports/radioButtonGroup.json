                "$value": "{ui-kit.globals.form.field.colors.background}"
              },
              "border-unselected": {
                "$type": "color",
                "$value": "{brand.layers.layer-2.elements.interactive.tone}"
              },
              "border-selected": {
                "$type": "color",
                "$value": "{brand.layers.layer-2.elements.interactive.tone}"
              },
              "icon-color": {
                "$type": "color",
                "$value": "{brand.layers.layer-2.elements.interactive.tone}"
              },
              "disabled-background": {
                "$type": "color",
                "$value": "{ui-kit.globals.form.field.colors.disabled-background}"
              },
              "disabled-border": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.400.color.tone}"
              },
              "disabled-icon": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.400.color.tone}"
              }
            },
            "layer-3": {
              "background-unselected": {
                "$type": "color",
                "$value": "{ui-kit.globals.form.field.colors.background}"
              },
              "background-selected": {
