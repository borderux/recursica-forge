              "$type": "dimension",
              "$value": {
                "value": 48,
                "unit": "px"
              }
            },
            "horizontal-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.lg}"
            },
            "icon": {
              "$type": "dimension",
              "$value": "{brand.dimensions.icons.default}"
            },
            "max-width": {
              "$type": "dimension",
              "$value": {
                "value": 464,
                "unit": "px"
              }
            },
            "min-width": {
              "$type": "dimension",
              "$value": {
                "value": 140,
                "unit": "px"
              }
            },
            "vertical-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.md}"
            },
            "vertical-gutter": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            }
          }
        }
      }
    },
    "components": {
      "radio-button-group": {
        "variants": {
          "layouts": {
            "stacked": {
              "properties": {
                "label-field-gap": {
                  "$type": "dimension",
                  "$value": "{ui-kit.globals.form.properties.label-field-gap-vertical}"
                },
                "top-bottom-margin": {
                  "$type": "dimension",
                  "$value": "{brand.dimensions.general.default}"
                }
              }
            },
            "side-by-side": {
              "properties": {
                "gutter": {
                  "$type": "dimension",
                  "$value": "{ui-kit.globals.form.properties.label-field-gap-horizontal}"
                },
                "vertical-padding": {
                  "$type": "dimension",
                  "$value": "{ui-kit.globals.form.properties.vertical-item-gap}"
                },
                "top-bottom-margin": {
                  "$type": "dimension",
                  "$value": {
                    "value": 0,
                    "unit": "px"
                  }
                }
              }
            }
          }
        },
        "properties": {
          "item-gap": {
            "$type": "dimension",
            "$value": "{ui-kit.globals.form.properties.vertical-item-gap}"
          },
          "padding": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.none}"
          }
        }
      },
