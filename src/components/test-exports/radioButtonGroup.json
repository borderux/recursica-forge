            "disabled-background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "disabled-text": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.400.color.tone}"
            }
          },
          "size": {
            "border-radius": {
              "$type": "dimension",
              "$value": "{brand.dimensions.border-radii.default}"
            },
            "border-size-default": {
              "$type": "dimension",
              "$value": {
                "value": 1,
                "unit": "px"
              }
            },
            "border-size-focus": {
              "$type": "dimension",
              "$value": {
                "value": 2,
                "unit": "px"
              }
            },
