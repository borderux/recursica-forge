                "$value": "{brand.layers.layer-1.elements.interactive.tone}"
              },
              "border-selected": {
                "$type": "color",
                "$value": "{brand.layers.layer-1.elements.interactive.tone}"
              },
              "icon-color": {
                "$type": "color",
                "$value": "{brand.layers.layer-1.elements.interactive.tone}"
              },
              "disabled-background": {
                "$type": "color",
                "$value": "{ui-kit.globals.form.field.colors.disabled-background}"
              },
              "disabled-border": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.400.color.tone}"
