              "thumb-selected": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.700.color.tone}"
              },
              "thumb-unselected": {
                "$type": "color",
                "$value": "{brand.palettes.palette-2.500.color.tone}"
              },
              "track-selected": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.600.color.tone}"
              },
              "track-unselected": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.warning.tone}"
              },
              "icon-selected": {
                "$type": "color",
