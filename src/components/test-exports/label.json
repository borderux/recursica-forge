{
  "ui-kit": {
    "globals": {
      "icon": {
        "style": {
          "$type": "string",
          "$value": "outline"
        }
      },
      "form": {
        "properties": {
          "label-field-gap-horizontal": {
            "$type": "dimension",
            "$value": "{brand.dimensions.gutters.horizontal}"
          },
          "label-field-gap-vertical": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "vertical-item-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          }
        },
        "field": {
          "colors": {
            "background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.tone}"
            },
            "background-read-only": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "border": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.default.color.tone}"
            },
            "border-focus": {
              "$type": "color",
              "$value": "{brand.palettes.palette-1.default.color.tone}"
            },
            "border-selected": {
              "$type": "color",
              "$value": "{brand.palettes.palette-1.default.color.tone}"
            },
            "border-error": {
              "$type": "color",
              "$value": "{brand.palettes.core-colors.alert.tone}"
            },
            "icon": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.on-tone}"
            },
            "text-valued": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.on-tone}"
            },
            "placeholder-text-opacity": {
              "$type": "number",
              "$value": "{brand.text-emphasis.low}"
            },
            "disabled-background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "disabled-text": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.400.color.tone}"
            }
          },
          "size": {
            "border-radius": {
              "$type": "dimension",
              "$value": "{brand.dimensions.border-radii.default}"
            },
            "border-size-default": {
              "$type": "dimension",
              "$value": {
                "value": 1,
                "unit": "px"
              }
            },
            "border-size-focus": {
              "$type": "dimension",
              "$value": {
                "value": 2,
                "unit": "px"
              }
            },
            "icon-text-gap": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            },
            "single-line-input-height": {
              "$type": "dimension",
              "$value": {
                "value": 48,
                "unit": "px"
              }
            },
            "horizontal-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.lg}"
            },
            "icon": {
              "$type": "dimension",
              "$value": "{brand.dimensions.icons.default}"
            },
            "max-width": {
              "$type": "dimension",
              "$value": {
                "value": 464,
                "unit": "px"
              }
            },
            "min-width": {
              "$type": "dimension",
              "$value": {
                "value": 140,
                "unit": "px"
              }
            },
            "vertical-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.md}"
            },
            "vertical-gutter": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            }
          }
        }
      }
    },
    "components": {
      "label": {
        "variants": {
          "layouts": {
            "stacked": {
              "properties": {
                "bottom-padding": {
                  "$type": "dimension",
                  "$value": "{brand.dimensions.general.default}"
                },
                "min-height": {
                  "$type": "dimension",
                  "$value": {
                    "value": 27,
                    "unit": "px"
                  }
                }
              },
              "variants": {
                "sizes": {
                  "default": {
                    "properties": {
                      "width": {
                        "$type": "dimension",
                        "$value": {
                          "value": 330,
                          "unit": "px"
                        }
                      }
                    }
                  },
                  "small": {
                    "properties": {
                      "width": {
                        "$type": "dimension",
                        "$value": {
                          "value": 80,
                          "unit": "px"
                        }
                      }
                    }
                  }
                }
              }
            },
            "side-by-side": {
              "properties": {
                "min-height": {
                  "$type": "dimension",
                  "$value": {
                    "value": 48,
                    "unit": "px"
                  }
                },
                "gutter": {
                  "$type": "dimension",
                  "$value": "{brand.dimensions.general.lg}"
                },
                "vertical-padding": {
                  "$type": "dimension",
                  "$value": "{brand.dimensions.general.default}"
                }
              },
              "variants": {
                "sizes": {
                  "default": {
                    "properties": {
                      "width": {
                        "$type": "dimension",
                        "$value": {
                          "value": 224,
                          "unit": "px"
                        }
                      }
                    }
                  },
                  "small": {
                    "properties": {
                      "width": {
                        "$type": "dimension",
                        "$value": {
                          "value": 80,
                          "unit": "px"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "properties": {
          "colors": {
            "layer-0": {
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.300.color.tone}"
              },
              "asterisk": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.600.color.tone}"
              }
            },
            "layer-1": {
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.warning.tone}"
              },
              "asterisk": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.warning.tone}"
              }
            },
            "layer-2": {
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.success.tone}"
              },
              "asterisk": {
                "$type": "color",
                "$value": "{brand.palettes.palette-2.600.color.tone}"
              }
            },
            "layer-3": {
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.200.color.tone}"
              },
              "asterisk": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.500.color.tone}"
              }
            }
          },
          "label-text": {
            "font-family": {
              "$type": "string",
              "$value": "{brand.fonts.primary}"
            },
            "font-size": {
              "$type": "dimension",
              "$value": "{tokens.font.sizes.xl}"
            },
            "font-weight": {
              "$type": "number",
              "$value": "{tokens.font.weights.thin}"
            },
            "letter-spacing": {
              "$type": "string",
              "$value": "{tokens.font.letter-spacings.wider}"
            },
            "line-height": {
              "$type": "number",
              "$value": "{tokens.font.line-heights.short}"
            },
            "text-decoration": {
              "$type": "string",
              "$value": "{tokens.font.decorations.underline}"
            },
            "text-transform": {
              "$type": "string",
              "$value": "{tokens.font.cases.uppercase}"
            },
            "font-style": {
              "$type": "string",
              "$value": "{tokens.font.styles.normal}"
            }
          },
          "optional-text": {
            "font-family": {
              "$type": "string",
              "$value": "{brand.fonts.secondary}"
            },
            "font-size": {
              "$type": "dimension",
              "$value": "{tokens.font.sizes.xl}"
            },
            "font-weight": {
              "$type": "number",
              "$value": "{tokens.font.weights.bold}"
            },
            "letter-spacing": {
              "$type": "string",
              "$value": "{tokens.font.letter-spacings.tightest}"
            },
            "line-height": {
              "$type": "number",
              "$value": "{tokens.font.line-heights.shorter}"
            },
            "text-decoration": {
              "$type": "string",
              "$value": "{tokens.font.decorations.underline}"
            },
            "text-transform": {
              "$type": "string",
              "$value": "{tokens.font.cases.lowercase}"
            },
            "font-style": {
              "$type": "color",
              "$value": "{tokens.font.styles.italic}"
            }
          },
          "required-indicator-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.md}"
          },
          "label-optional-text-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "edit-icon-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.xl}"
          },
          "optional-text-opacity": {
            "$type": "number",
            "$value": "{tokens.opacities.mist}"
          }
        }
      }
    }
  }
}