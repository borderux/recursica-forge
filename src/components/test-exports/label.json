{
  "ui-kit": {
    "components": {
      "label": {
        "variants": {
          "layouts": {
            "stacked": {
              "properties": {
                "bottom-padding": {
                  "$type": "dimension",
                  "$value": "{brand.dimensions.general.default}"
                },
                "min-height": {
                  "$type": "dimension",
                  "$value": {
                    "value": 22,
                    "unit": "px"
                  }
                }
              },
              "variants": {
                "sizes": {
                  "default": {
                    "properties": {
                      "width": {
                        "$type": "dimension",
                        "$value": {
                          "value": 226,
                          "unit": "px"
                        }
                      }
                    }
                  },
                  "small": {
                    "properties": {
                      "width": {
                        "$type": "dimension",
                        "$value": {
                          "value": 82,
                          "unit": "px"
                        }
                      }
                    }
                  }
                }
              }
            },
            "side-by-side": {
              "properties": {
                "min-height": {
                  "$type": "dimension",
                  "$value": {
                    "value": 50,
                    "unit": "px"
                  }
                },
                "gutter": {
                  "$type": "dimension",
                  "$value": "{ui-kit.globals.form.properties.label-field-gap-horizontal}"
                },
                "vertical-padding": {
                  "$type": "dimension",
                  "$value": "{ui-kit.globals.form.properties.vertical-item-gap}"
                }
              },
              "variants": {
                "sizes": {
                  "default": {
                    "properties": {
                      "width": {
                        "$type": "dimension",
                        "$value": {
                          "value": 226,
                          "unit": "px"
                        }
                      }
                    }
                  },
                  "small": {
                    "properties": {
                      "width": {
                        "$type": "dimension",
                        "$value": {
                          "value": 82,
                          "unit": "px"
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        },
        "properties": {
          "colors": {
            "layer-0": {
              "text": {
                "$type": "color",
                "$value": "{brand.layers.layer-0.elements.text.color}"
              },
              "asterisk": {
                "$type": "color",
                "$value": "{brand.layers.layer-0.elements.text.alert}"
              }
            },
            "layer-1": {
              "text": {
                "$type": "color",
                "$value": "{brand.layers.layer-1.elements.text.color}"
              },
              "asterisk": {
                "$type": "color",
                "$value": "{brand.layers.layer-1.elements.text.alert}"
              }
            },
            "layer-2": {
              "text": {
                "$type": "color",
                "$value": "{brand.layers.layer-2.elements.text.color}"
              },
              "asterisk": {
                "$type": "color",
                "$value": "{brand.layers.layer-2.elements.text.alert}"
              }
            },
            "layer-3": {
              "text": {
                "$type": "color",
                "$value": "{brand.layers.layer-3.elements.text.color}"
              },
              "asterisk": {
                "$type": "color",
                "$value": "{brand.layers.layer-3.elements.text.alert}"
              }
            }
          },
          "label-text": {
            "font-family": {
              "$type": "string",
              "$value": "{brand.fonts.tertiary}"
            },
            "font-size": {
              "$type": "dimension",
              "$value": "{tokens.font.sizes.sm}"
            },
            "font-weight": {
              "$type": "number",
              "$value": "{tokens.font.weights.regular}"
            },
            "letter-spacing": {
              "$type": "string",
              "$value": "{tokens.font.letter-spacings.default}"
            },
            "line-height": {
              "$type": "number",
              "$value": "{tokens.font.line-heights.default}"
            },
            "text-decoration": {
              "$type": "string",
              "$value": "{tokens.font.decorations.none}"
            },
            "text-transform": {
              "$type": "string",
              "$value": "{tokens.font.cases.original}"
            },
            "font-style": {
              "$type": "string",
              "$value": "{tokens.font.styles.normal}"
            }
          },
          "optional-text": {
            "font-family": {
              "$type": "string",
              "$value": "{brand.fonts.tertiary}"
            },
            "font-size": {
              "$type": "dimension",
              "$value": "{tokens.font.sizes.xs}"
            },
            "font-weight": {
              "$type": "number",
              "$value": "{tokens.font.weights.regular}"
            },
            "letter-spacing": {
              "$type": "string",
              "$value": "{tokens.font.letter-spacings.default}"
            },
            "line-height": {
              "$type": "number",
              "$value": "{tokens.font.line-heights.default}"
            },
            "text-decoration": {
              "$type": "string",
              "$value": "{tokens.font.decorations.none}"
            },
            "text-transform": {
              "$type": "string",
              "$value": "{tokens.font.cases.original}"
            },
            "font-style": {
              "$type": "string",
              "$value": "{tokens.font.styles.normal}"
            }
          },
          "required-indicator-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "label-optional-text-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.md}"
          },
          "edit-icon-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.md}"
          },
          "optional-text-opacity": {
            "$type": "number",
            "$value": "{brand.text-emphasis.low}"
          }
        }
      }
    }
  }
}
