{
  "ui-kit": {
    "globals": {
      "icon": {
        "style": {
          "$type": "string",
          "$value": "outline"
        }
      },
      "form": {
        "properties": {
          "label-field-gap-horizontal": {
            "$type": "dimension",
            "$value": "{brand.dimensions.gutters.horizontal}"
          },
          "label-field-gap-vertical": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "vertical-item-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          }
        },
        "field": {
          "colors": {
            "background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.tone}"
            },
            "background-read-only": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "border": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.default.color.tone}"
            },
            "border-focus": {
              "$type": "color",
              "$value": "{brand.palettes.palette-1.default.color.tone}"
            },
            "border-selected": {
              "$type": "color",
              "$value": "{brand.palettes.palette-1.default.color.tone}"
            },
            "border-error": {
              "$type": "color",
              "$value": "{brand.palettes.core-colors.alert.tone}"
            },
            "icon": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.on-tone}"
            },
            "text-valued": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.on-tone}"
            },
            "placeholder-text-opacity": {
              "$type": "number",
              "$value": "{brand.text-emphasis.low}"
            },
            "disabled-background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "disabled-text": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.400.color.tone}"
            }
          },
          "size": {
            "border-radius": {
              "$type": "dimension",
              "$value": "{brand.dimensions.border-radii.default}"
            },
            "border-size-default": {
              "$type": "dimension",
              "$value": {
                "value": 1,
                "unit": "px"
              }
            },
            "border-size-focus": {
              "$type": "dimension",
              "$value": {
                "value": 2,
                "unit": "px"
              }
            },
            "icon-text-gap": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            },
            "single-line-input-height": {
              "$type": "dimension",
              "$value": {
                "value": 48,
                "unit": "px"
              }
            },
            "horizontal-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.lg}"
            },
            "icon": {
              "$type": "dimension",
              "$value": "{brand.dimensions.icons.default}"
            },
            "max-width": {
              "$type": "dimension",
              "$value": {
                "value": 464,
                "unit": "px"
              }
            },
            "min-width": {
              "$type": "dimension",
              "$value": {
                "value": 140,
                "unit": "px"
              }
            },
            "vertical-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.md}"
            },
            "vertical-gutter": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            }
          }
        }
      }
    },
    "components": {
      "hover-card-popover": {
        "properties": {
          "colors": {
            "layer-0": {
              "background": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.000.color.tone}"
              },
              "content": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.300.color.tone}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.success.tone}"
              }
            },
            "layer-1": {
              "background": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.300.color.tone}"
              },
              "content": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.000.color.tone}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.alert.tone}"
              }
            },
            "layer-2": {
              "background": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.600.color.tone}"
              },
              "content": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.100.color.tone}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.success.tone}"
              }
            },
            "layer-3": {
              "background": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.success.tone}"
              },
              "content": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.700.color.tone}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.000.color.tone}"
              }
            }
          },
          "content-text": {
            "font-family": {
              "$type": "fontFamily",
              "$value": "{brand.fonts.primary}"
            },
            "font-size": {
              "$type": "dimension",
              "$value": "{tokens.font.sizes.2xl}"
            },
            "font-weight": {
              "$type": "fontWeight",
              "$value": "{tokens.font.weights.thin}"
            },
            "letter-spacing": {
              "$type": "string",
              "$value": "{tokens.font.letter-spacings.tightest}"
            },
            "line-height": {
              "$type": "number",
              "$value": "{tokens.font.line-heights.tallest}"
            },
            "font-style": {
              "$type": "string",
              "$value": "{brand.typography.body.fontStyle}"
            },
            "text-decoration": {
              "$type": "string",
              "$value": "{tokens.font.decorations.underline}"
            },
            "text-transform": {
              "$type": "string",
              "$value": "{tokens.font.cases.uppercase}"
            }
          },
          "border-radius": {
            "$type": "dimension",
            "$value": "{brand.dimensions.border-radii.none}"
          },
          "border-size": {
            "$type": "dimension",
            "$value": {
              "value": 3,
              "unit": "px"
            }
          },
          "horizontal-padding": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "vertical-padding": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.sm}"
          },
          "min-width": {
            "$type": "dimension",
            "$value": {
              "value": 488,
              "unit": "px"
            }
          },
          "max-width": {
            "$type": "dimension",
            "$value": {
              "value": 648,
              "unit": "px"
            }
          },
          "beak-size": {
            "$type": "dimension",
            "$value": {
              "value": 24,
              "unit": "px"
            }
          },
          "elevation": {
            "$type": "elevation",
            "$value": "{brand.elevations.elevation-2}"
          }
        }
      }
    }
  }
}