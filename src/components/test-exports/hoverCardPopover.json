{
  "ui-kit": {
    "components": {
      "hover-card-popover": {
        "properties": {
          "colors": {
            "layer-0": {
              "background": {
                "$type": "color",
                "$value": "{brand.layers.layer-0.properties.surface}"
              },
              "content": {
                "$type": "color",
                "$value": "{brand.layers.layer-0.elements.text.color}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.layers.layer-0.properties.border-color}"
              }
            },
            "layer-1": {
              "background": {
                "$type": "color",
                "$value": "{brand.layers.layer-1.properties.surface}"
              },
              "content": {
                "$type": "color",
                "$value": "{brand.layers.layer-1.elements.text.color}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.layers.layer-1.properties.border-color}"
              }
            },
            "layer-2": {
              "background": {
                "$type": "color",
                "$value": "{brand.layers.layer-2.properties.surface}"
              },
              "content": {
                "$type": "color",
                "$value": "{brand.layers.layer-2.elements.text.color}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.layers.layer-2.properties.border-color}"
              }
            },
            "layer-3": {
              "background": {
                "$type": "color",
                "$value": "{brand.layers.layer-3.properties.surface}"
              },
              "content": {
                "$type": "color",
                "$value": "{brand.layers.layer-3.elements.text.color}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.layers.layer-3.properties.border-color}"
              }
            }
          },
          "content-text": {
            "font-family": {
              "$type": "string",
              "$value": "{brand.fonts.tertiary}"
            },
            "font-size": {
              "$type": "dimension",
              "$value": "{tokens.font.sizes.md}"
            },
            "font-weight": {
              "$type": "number",
              "$value": "{tokens.font.weights.regular}"
            },
            "letter-spacing": {
              "$type": "string",
              "$value": "{tokens.font.letter-spacings.default}"
            },
            "line-height": {
              "$type": "number",
              "$value": "{tokens.font.line-heights.default}"
            },
            "text-decoration": {
              "$type": "string",
              "$value": "{tokens.font.decorations.none}"
            },
            "text-transform": {
              "$type": "string",
              "$value": "{tokens.font.cases.original}"
            },
            "font-style": {
              "$type": "string",
              "$value": "{tokens.font.styles.normal}"
            }
          },
          "border-radius": {
            "$type": "dimension",
            "$value": "{brand.dimensions.border-radii.lg}"
          },
          "border-size": {
            "$type": "dimension",
            "$value": {
              "value": 3,
              "unit": "px"
            }
          },
          "horizontal-padding": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.xl}"
          },
          "vertical-padding": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.xl}"
          },
          "min-width": {
            "$type": "dimension",
            "$value": {
              "value": 202,
              "unit": "px"
            }
          },
          "max-width": {
            "$type": "dimension",
            "$value": {
              "value": 402,
              "unit": "px"
            }
          },
          "beak-size": {
            "$type": "dimension",
            "$value": {
              "value": 18,
              "unit": "px"
            }
          },
          "elevation": {
            "$value": "{brand.elevations.elevation-1}",
            "$extensions": {
              "recursica.type": "elevation"
            }
          }
        }
      }
    }
  }
}
