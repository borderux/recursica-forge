{
  "ui-kit": {
    "globals": {
      "icon": {
        "style": {
          "$type": "string",
          "$value": "outline"
        }
      },
      "form": {
        "properties": {
          "label-field-gap-horizontal": {
            "$type": "dimension",
            "$value": "{brand.dimensions.gutters.horizontal}"
          },
          "label-field-gap-vertical": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "vertical-item-gap": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          }
        },
        "field": {
          "colors": {
            "background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.tone}"
            },
            "background-read-only": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "border": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.default.color.tone}"
            },
            "border-focus": {
              "$type": "color",
              "$value": "{brand.palettes.palette-1.default.color.tone}"
            },
            "border-selected": {
              "$type": "color",
              "$value": "{brand.palettes.palette-1.default.color.tone}"
            },
            "border-error": {
              "$type": "color",
              "$value": "{brand.palettes.core-colors.alert.tone}"
            },
            "icon": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.on-tone}"
            },
            "text-valued": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.000.color.on-tone}"
            },
            "placeholder-text-opacity": {
              "$type": "number",
              "$value": "{brand.text-emphasis.low}"
            },
            "disabled-background": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.100.color.tone}"
            },
            "disabled-text": {
              "$type": "color",
              "$value": "{brand.palettes.neutral.400.color.tone}"
            }
          },
          "size": {
            "border-radius": {
              "$type": "dimension",
              "$value": "{brand.dimensions.border-radii.default}"
            },
            "border-size-default": {
              "$type": "dimension",
              "$value": {
                "value": 1,
                "unit": "px"
              }
            },
            "border-size-focus": {
              "$type": "dimension",
              "$value": {
                "value": 2,
                "unit": "px"
              }
            },
            "icon-text-gap": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            },
            "single-line-input-height": {
              "$type": "dimension",
              "$value": {
                "value": 48,
                "unit": "px"
              }
            },
            "horizontal-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.lg}"
            },
            "icon": {
              "$type": "dimension",
              "$value": "{brand.dimensions.icons.default}"
            },
            "max-width": {
              "$type": "dimension",
              "$value": {
                "value": 464,
                "unit": "px"
              }
            },
            "min-width": {
              "$type": "dimension",
              "$value": {
                "value": 140,
                "unit": "px"
              }
            },
            "vertical-padding": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.md}"
            },
            "vertical-gutter": {
              "$type": "dimension",
              "$value": "{brand.dimensions.general.default}"
            }
          }
        }
      }
    },
    "components": {
      "tooltip": {
        "properties": {
          "elevation": {
            "$type": "elevation",
            "$value": "{brand.elevations.elevation-3}"
          },
          "border-size": {
            "$type": "dimension",
            "$value": {
              "value": 3,
              "unit": "px"
            }
          },
          "vertical-padding": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.default}"
          },
          "horizontal-padding": {
            "$type": "dimension",
            "$value": "{brand.dimensions.general.lg}"
          },
          "border-radius": {
            "$type": "dimension",
            "$value": "{brand.dimensions.border-radii.lg}"
          },
          "min-width": {
            "$type": "dimension",
            "$value": {
              "value": 201,
              "unit": "px"
            }
          },
          "max-width": {
            "$type": "dimension",
            "$value": {
              "value": 119,
              "unit": "px"
            }
          },
          "beak-size": {
            "$type": "dimension",
            "$value": {
              "value": 30,
              "unit": "px"
            }
          },
          "beak-inset": {
            "$type": "dimension",
            "$value": {
              "value": 20,
              "unit": "px"
            }
          },
          "min-height": {
            "$type": "dimension",
            "$value": {
              "value": 100,
              "unit": "px"
            }
          },
          "colors": {
            "layer-0": {
              "background": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.warning.tone}"
              },
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.success.tone}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.600.color.tone}"
              }
            },
            "layer-1": {
              "background": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.200.color.tone}"
              },
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.alert.tone}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.400.color.tone}"
              }
            },
            "layer-2": {
              "background": {
                "$type": "color",
                "$value": "{brand.palettes.palette-2.100.color.tone}"
              },
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.500.color.tone}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.palettes.palette-1.400.color.tone}"
              }
            },
            "layer-3": {
              "background": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.700.color.tone}"
              },
              "text": {
                "$type": "color",
                "$value": "{brand.palettes.core-colors.warning.tone}"
              },
              "border-color": {
                "$type": "color",
                "$value": "{brand.palettes.neutral.100.color.tone}"
              }
            }
          },
          "text": {
            "font-family": {
              "$type": "string",
              "$value": "{brand.fonts.secondary}"
            },
            "font-size": {
              "$type": "dimension",
              "$value": "{tokens.font.sizes.md}"
            },
            "font-weight": {
              "$type": "number",
              "$value": "{tokens.font.weights.light}"
            },
            "letter-spacing": {
              "$type": "string",
              "$value": "{tokens.font.letter-spacings.tightest}"
            },
            "line-height": {
              "$type": "number",
              "$value": "{tokens.font.line-heights.taller}"
            },
            "text-decoration": {
              "$type": "string",
              "$value": "{tokens.font.decorations.underline}"
            },
            "text-transform": {
              "$type": "string",
              "$value": "{tokens.font.cases.uppercase}"
            },
            "font-style": {
              "$type": "string",
              "$value": "{tokens.font.styles.italic}"
            }
          }
        }
      }
    }
  }
}